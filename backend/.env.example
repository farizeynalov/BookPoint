APP_NAME=BookPoint API
APP_ENV=development
API_V1_PREFIX=/api/v1

SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PAYMENT_WEBHOOK_SECRET=change-this-payment-webhook-secret
PAYMENT_PENDING_EXPIRATION_MINUTES=15
PAYMENT_EXPIRATION_CHECK_INTERVAL_SECONDS=60

DATABASE_URL=postgresql+psycopg://bookpoint:bookpoint@db:5432/bookpoint
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

DEFAULT_CITY=Baku
DEFAULT_TIMEZONE=Asia/Baku

# Preferred format (JSON array):
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Also supported:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
