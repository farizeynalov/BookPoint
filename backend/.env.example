APP_NAME=BookPoint API
APP_ENV=development
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
ENABLE_DOCS=true
ENABLE_METRICS=true
ENABLE_ADMIN_INTERNAL_ENDPOINTS=true
ENABLE_RATE_LIMITING=true

SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PAYMENT_WEBHOOK_SECRET=change-this-payment-webhook-secret
WHATSAPP_ENABLED=true
WHATSAPP_VERIFY_TOKEN=bookpoint_verify_token_123
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_OUTBOUND_TIMEOUT_SECONDS=10
WHATSAPP_OUTBOUND_MAX_RETRIES=3
WHATSAPP_OUTBOUND_RETRY_BACKOFF_SECONDS=1
PAYMENT_PENDING_EXPIRATION_MINUTES=15
PAYMENT_EXPIRATION_CHECK_INTERVAL_SECONDS=60
PAYOUT_PROCESSING_INTERVAL_SECONDS=300
PAYOUT_PROCESSING_PROVIDER_NAME=mock
REMINDER_SCHEDULE_INTERVAL_SECONDS=300
REMINDER_LOOKAHEAD_MINUTES=60
OPS_CLEANUP_INTERVAL_SECONDS=3600
DOMAIN_EVENTS_RETENTION_DAYS=90
IDEMPOTENCY_KEYS_RETENTION_DAYS=14
RATE_LIMIT_WHATSAPP_INBOUND_LIMIT=60
RATE_LIMIT_WHATSAPP_INBOUND_WINDOW_SECONDS=60

DATABASE_URL=postgresql+psycopg://bookpoint:bookpoint@db:5432/bookpoint
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

DEFAULT_CITY=Baku
DEFAULT_TIMEZONE=Asia/Baku

# Preferred format (JSON array):
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Also supported:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
